{erl_opts, [debug_info]}.

{deps, [
    %% amqtt_client is provided via _checkouts/ during local development;
    %% replace this with a hex pin when published.
    {amqtt_client, "0.1.0"}
]}.

{project_plugins, [atomvm_rebar3_plugin]}.

{atomvm_rebar3_plugin, [
    {packbeam, [{start, client_pub_sub_e2e}, prune]}
]}.

{shell, [
    {apps, [client_pub_sub_e2e]}
]}.
